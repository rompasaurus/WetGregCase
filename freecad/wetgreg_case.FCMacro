    ("thumb_dish_r",12.00,"Thumb dish sphere radius"),
    ("thumb_dish_d",0.60,"Thumb dish depth"),
    ("thumb_sock", 3.70, "Thumb socket (square) - was 3.30; +0.2mm clearance per side"),
